<UserControl x:Class="EventPlanner.Views.EventDetailsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="EventDetailsPage_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,18">
            <Button Content="← Back" Style="{StaticResource SecondaryButton}" Click="Back_Click"
                    DockPanel.Dock="Right" Margin="0"/>
            <TextBlock x:Name="TitleText" Text="Event details" Style="{StaticResource PageTitle}" Margin="0"/>
        </DockPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Date" Style="{StaticResource CardLabel}"/>
                    <TextBlock x:Name="DateText" Style="{StaticResource CardValue}" FontSize="16"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Location" Style="{StaticResource CardLabel}"/>
                    <TextBlock x:Name="LocationText" Style="{StaticResource CardValue}" FontSize="16"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Capacity" Style="{StaticResource CardLabel}"/>
                    <TextBlock x:Name="CapacityText" Style="{StaticResource CardValue}" FontSize="16"/>
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="Status" Style="{StaticResource CardLabel}"/>
                    <TextBlock x:Name="StatusText" Style="{StaticResource CardValue}" FontSize="16"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0">

            <TabItem Header="Info">
                <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Description" Style="{StaticResource CardLabel}"/>
                        <TextBlock x:Name="DescriptionText" Margin="0,6,0,0" TextWrapping="Wrap"
                                   Foreground="{StaticResource HeaderText}"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="Registrations">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="RegistrationsGrid" Grid.Row="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding RegistrationId}" Width="60"/>
                            <DataGridTextColumn Header="Person" Binding="{Binding PersonName}" Width="*"/>
                            <DataGridTextColumn Header="Ticket" Binding="{Binding TicketType}" Width="120"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat={}{0:0.00} €}" Width="100"/>
                            <DataGridTextColumn Header="Paid" Binding="{Binding PaidAmount, StringFormat={}{0:0.00} €}" Width="100"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                            <DataGridTextColumn Header="Checked in" Binding="{Binding CheckedInAt, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Add Registration" Style="{StaticResource PrimaryButton}" Click="AddRegistration_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Speakers">
                <DataGrid x:Name="SpeakersGrid" Margin="0,12,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding PersonId}" Width="60"/>
                        <DataGridTextColumn Header="Full name" Binding="{Binding FullName}" Width="*"/>
                        <DataGridTextColumn Header="Topic" Binding="{Binding Topic}" Width="220"/>
                        <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="140"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Finance">
                <StackPanel Margin="0,12,0,0">
                    <UniformGrid Columns="5" Margin="0,0,0,14">
                        <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Expected" Style="{StaticResource CardLabel}"/>
                                <TextBlock x:Name="ExpectedCard" Style="{StaticResource CardValue}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Paid" Style="{StaticResource CardLabel}"/>
                                <TextBlock x:Name="PaidCard" Style="{StaticResource CardValue}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Outstanding" Style="{StaticResource CardLabel}"/>
                                <TextBlock x:Name="OutstandingCard" Style="{StaticResource CardValue}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Expenses" Style="{StaticResource CardLabel}"/>
                                <TextBlock x:Name="ExpensesCard" Style="{StaticResource CardValue}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Profit" Style="{StaticResource CardLabel}"/>
                                <TextBlock x:Name="ProfitCard" Style="{StaticResource CardValue}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                    <DataGrid x:Name="ExpensesGrid" Height="280">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ExpenseId}" Width="60"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:0.00} €}" Width="120"/>
                            <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="200"/>
                            <DataGridTextColumn Header="Paid at" Binding="{Binding PaidAt, StringFormat=\{0:dd.MM.yyyy\}}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
