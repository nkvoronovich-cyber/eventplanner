<Window x:Class="EventPlanner.Views.EventFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Event Form" Height="540" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource PageBackground}">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Event details" FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource HeaderText}" Margin="0,0,0,18"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Title" Style="{StaticResource CardLabel}"/>
            <TextBox x:Name="TitleBox" Height="32" Padding="6,4" Margin="0,4,0,12"/>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Date" Style="{StaticResource CardLabel}"/>
                    <DatePicker x:Name="DatePick" Height="32" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Time (HH:mm)" Style="{StaticResource CardLabel}"/>
                    <TextBox x:Name="TimeBox" Height="32" Padding="6,4" Margin="0,4,0,0" Text="10:00"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="Location" Style="{StaticResource CardLabel}"/>
            <TextBox x:Name="LocationBox" Height="32" Padding="6,4" Margin="0,4,0,12"/>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Capacity" Style="{StaticResource CardLabel}"/>
                    <TextBox x:Name="CapacityBox" Height="32" Padding="6,4" Margin="0,4,0,0" Text="50"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Status" Style="{StaticResource CardLabel}"/>
                    <ComboBox x:Name="StatusBox" Height="32" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="Description" Style="{StaticResource CardLabel}"/>
            <TextBox x:Name="DescriptionBox" Height="80" Padding="6,4" Margin="0,4,0,0"
                     TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Save" Style="{StaticResource PrimaryButton}" Click="Save_Click" Width="100"/>
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Click="Cancel_Click" Width="100" Margin="0"/>
        </StackPanel>
    </Grid>
</Window>
