<Window x:Class="EventPlanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EventPlanner.ViewModels"
        xmlns:views="clr-namespace:EventPlanner.Views"
        Title="EventPlanner" Height="780" Width="1280" MinHeight="700" MinWidth="1200"
        WindowStartupLocation="CenterScreen">

    <Grid Background="{StaticResource PageBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource NavBackground}">
            <DockPanel Margin="18,22,18,18" LastChildFill="True">

                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,28">
                    <Image x:Name="LogoImage" MaxHeight="56" Stretch="Uniform" HorizontalAlignment="Left"
                           Margin="0,0,0,10" Visibility="Collapsed"/>
                    <TextBlock Text="EventPlanner" Foreground="White" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="Desktop event manager" Foreground="#9AAFCB" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <Rectangle Height="1" Fill="#2C4F86" Margin="0,8,0,10"/>
                    <TextBlock Text="© EventPlanner 2026" Foreground="#7B91AE" FontSize="11" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel>
                    <Button Content="Events" Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Events"/>
                    <Button Content="Registrations" Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Registrations"/>
                    <Button Content="People" Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="People"/>
                    <Button Content="Check-in" Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="CheckIn"/>
                    <Button Content="Finance" Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Finance"/>
                    <Button Content="Reports" Style="{StaticResource NavButton}"
                            Command="{Binding NavigateCommand}" CommandParameter="Reports"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <ContentControl Grid.Column="1" Margin="28" Content="{Binding}">
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Setter Property="ContentTemplate">
                        <Setter.Value>
                            <DataTemplate><views:EventsPage/></DataTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentPage}" Value="Registrations">
                            <Setter Property="ContentTemplate">
                                <Setter.Value><DataTemplate><views:RegistrationsPage/></DataTemplate></Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentPage}" Value="People">
                            <Setter Property="ContentTemplate">
                                <Setter.Value><DataTemplate><views:PeoplePage/></DataTemplate></Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentPage}" Value="CheckIn">
                            <Setter Property="ContentTemplate">
                                <Setter.Value><DataTemplate><views:CheckInPage/></DataTemplate></Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentPage}" Value="Finance">
                            <Setter Property="ContentTemplate">
                                <Setter.Value><DataTemplate><views:FinancePage/></DataTemplate></Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentPage}" Value="Reports">
                            <Setter Property="ContentTemplate">
                                <Setter.Value><DataTemplate><views:ReportsPage/></DataTemplate></Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentPage}" Value="EventDetails">
                            <Setter Property="ContentTemplate">
                                <Setter.Value><DataTemplate><views:EventDetailsPage/></DataTemplate></Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>
    </Grid>
</Window>
