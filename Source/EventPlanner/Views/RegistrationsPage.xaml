<UserControl x:Class="EventPlanner.Views.RegistrationsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Registrations" Style="{StaticResource PageTitle}"/>

        <DataGrid x:Name="RegistrationsGrid" Grid.Row="1" ItemsSource="{Binding RegistrationRows}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding RegistrationId}" Width="60"/>
                <DataGridTextColumn Header="Event" Binding="{Binding EventTitle}" Width="*"/>
                <DataGridTextColumn Header="Person" Binding="{Binding PersonName}" Width="*"/>
                <DataGridTextColumn Header="Ticket" Binding="{Binding TicketType}" Width="120"/>
                <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat={}{0:0.00} €}" Width="100"/>
                <DataGridTextColumn Header="Paid" Binding="{Binding PaidAmount, StringFormat={}{0:0.00} €}" Width="100"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110"/>
                <DataGridTextColumn Header="Checked in" Binding="{Binding CheckedInAt, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,14,0,0">
            <Button Content="New Registration" Style="{StaticResource PrimaryButton}" Click="NewRegistration_Click"/>
            <Button Content="Edit" Style="{StaticResource SecondaryButton}" Click="EditRegistration_Click"/>
            <Button Content="Cancel registration" Style="{StaticResource SecondaryButton}" Click="CancelRegistration_Click"/>
            <Button Content="Delete" Style="{StaticResource DangerButton}" Click="DeleteRegistration_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
