<UserControl x:Class="EventPlanner.Views.PeoplePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="People" Style="{StaticResource PageTitle}"/>

        <Grid Grid.Row="1" Margin="0,0,0,14">
            <TextBox x:Name="SearchBox" Height="36" Padding="10,6" TextChanged="SearchBox_TextChanged"
                     ToolTip="Filter by name, phone or email"/>
            <TextBlock Text="Search by name, phone or email" Foreground="{StaticResource MutedText}"
                       IsHitTestVisible="False" VerticalAlignment="Center" Margin="12,0,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <DataGrid x:Name="PeopleGrid" Grid.Row="2" ItemsSource="{Binding People}" SelectionChanged="PeopleGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding PersonId}" Width="60"/>
                <DataGridTextColumn Header="Full name" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="150"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="220"/>
                <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="110"/>
                <DataGridTextColumn Header="Active" Binding="{Binding IsActive}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,14,0,0">
            <Button Content="Add Person" Style="{StaticResource PrimaryButton}" Click="AddPerson_Click"/>
            <Button Content="Edit" Style="{StaticResource SecondaryButton}" Click="EditPerson_Click"/>
            <Button x:Name="ToggleActiveButton" Content="Deactivate" Style="{StaticResource SecondaryButton}" Click="ToggleActive_Click"/>
            <Button Content="Delete" Style="{StaticResource DangerButton}" Click="DeletePerson_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
