<UserControl x:Class="EventPlanner.Views.EventsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="Events" Style="{StaticResource PageTitle}" Margin="0" DockPanel.Dock="Left"/>
        </DockPanel>

        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox" Height="36" Padding="10,6"
                     TextChanged="SearchBox_TextChanged"
                     ToolTip="Filter by title, location or status"/>
            <TextBlock Text="Search by title, location or status" Foreground="{StaticResource MutedText}"
                       IsHitTestVisible="False" VerticalAlignment="Center" Margin="12,0,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <UniformGrid Grid.Row="2" Columns="4" Margin="0,0,0,14">
            <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Expected income" Style="{StaticResource CardLabel}"/>
                    <TextBlock Text="{Binding ExpectedIncome, StringFormat={}{0:0.00} €}" Style="{StaticResource CardValue}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Paid income" Style="{StaticResource CardLabel}"/>
                    <TextBlock Text="{Binding PaidIncome, StringFormat={}{0:0.00} €}" Style="{StaticResource CardValue}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Outstanding" Style="{StaticResource CardLabel}"/>
                    <TextBlock Text="{Binding Outstanding, StringFormat={}{0:0.00} €}" Style="{StaticResource CardValue}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Total events" Style="{StaticResource CardLabel}"/>
                    <TextBlock Text="{Binding Events.Count}" Style="{StaticResource CardValue}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <DataGrid x:Name="EventsGrid" Grid.Row="3" ItemsSource="{Binding EventRows}" MouseDoubleClick="EventsGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding EventId}" Width="60"/>
                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="Date" Binding="{Binding StartAt, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" Width="150"/>
                <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="140"/>
                <DataGridTextColumn Header="Capacity" Binding="{Binding Capacity}" Width="90"/>
                <DataGridTextColumn Header="Registered" Binding="{Binding Registered}" Width="100"/>
                <DataGridTextColumn Header="Paid" Binding="{Binding Paid, StringFormat={}{0:0.00} €}" Width="110"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,14,0,0">
            <Button Content="New Event" Style="{StaticResource PrimaryButton}" Click="NewEvent_Click"/>
            <Button Content="Details" Style="{StaticResource SecondaryButton}" Click="Details_Click"/>
            <Button Content="Edit" Style="{StaticResource SecondaryButton}" Click="EditEvent_Click"/>
            <Button Content="Archive" Style="{StaticResource SecondaryButton}" Click="ArchiveEvent_Click"/>
            <Button Content="Delete" Style="{StaticResource DangerButton}" Click="DeleteEvent_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
